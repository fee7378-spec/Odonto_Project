{
  "entities": {
    "Patient": {
      "title": "Patient",
      "description": "Information about a patient",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "code": { "type": "string" },
        "name": { "type": "string" },
        "photoUrl": { "type": "string" },
        "cpf": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "lastVisit": { "type": "string" },
        "nextVisit": { "type": "string" },
        "status": { "type": "string" },
        "alergies": { "type": "array" },
        "medications": { "type": "array" },
        "history": { "type": "array" }
      },
      "required": ["id", "name", "cpf", "phone", "email", "status"]
    },
    "Appointment": {
      "title": "Appointment",
      "description": "Dental appointment",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "patientId": { "type": "string" },
        "dentistId": { "type": "string" },
        "date": { "type": "string" },
        "duration": { "type": "number" },
        "status": { "type": "string" },
        "treatmentType": { "type": "string" },
        "notes": { "type": "string" }
      },
      "required": ["id", "patientId", "dentistId", "date", "duration", "status", "treatmentType"]
    },
    "Dentist": {
      "title": "Dentist",
      "description": "Dentist information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "specialty": { "type": "string" },
        "photoUrl": { "type": "string" },
        "commission": { "type": "number" },
        "active": { "type": "boolean" }
      },
      "required": ["id", "name", "specialty", "commission", "active"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Financial record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string" },
        "category": { "type": "string" },
        "amount": { "type": "number" },
        "date": { "type": "string" },
        "status": { "type": "string" },
        "patientId": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["id", "type", "category", "amount", "date", "status", "description"]
    }
  },
  "firestore": {
    "/patients/{patientId}": {
      "schema": "Patient",
      "description": "Patient records"
    },
    "/appointments/{appointmentId}": {
      "schema": "Appointment",
      "description": "Appointment schedules"
    },
    "/dentists/{dentistId}": {
      "schema": "Dentist",
      "description": "Dentist profiles"
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Financial transactions"
    }
  }
}
