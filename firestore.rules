rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Master Deny-All Gate
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isStaff() {
      return isSignedIn(); // For now any authenticated user is staff
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 3. Validation Helpers
    function isValidPatient(data) {
      return data.keys().hasAll(['name', 'cpf', 'phone', 'email', 'status']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.cpf is string && data.cpf.size() <= 20 &&
             data.email is string && data.email.size() <= 100 &&
             (data.get('code', '') is string) &&
             data.status in ['active', 'inactive'];
    }

    function isValidAppointment(data) {
      return data.keys().hasAll(['patientId', 'date', 'status', 'treatmentType']) &&
             data.patientId is string &&
             data.date is string &&
             data.status in ['scheduled', 'confirmed', 'ongoing', 'finished', 'cancelled'];
    }

    function isValidTransaction(data) {
      return data.keys().hasAll(['type', 'category', 'amount', 'date', 'status', 'description']) &&
             data.type in ['income', 'expense'] &&
             data.amount is number && data.amount >= 0 &&
             data.status in ['paid', 'pending'];
    }

    // 4. Collection Matches
    match /patients/{patientId} {
      allow read: if isStaff();
      allow create: if isStaff() && isValidPatient(incoming());
      allow update: if isStaff() && isValidPatient(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly([
          'name', 'photoUrl', 'cpf', 'phone', 'email', 'status', 'alergies', 
          'medications', 'odontogramState', 'history', 'lastVisit', 'nextVisit'
        ])
      );
      allow delete: if isStaff();
    }

    match /appointments/{appointmentId} {
      allow read: if isStaff();
      allow create: if isStaff() && isValidAppointment(incoming());
      allow update: if isStaff() && isValidAppointment(incoming()) && (
        // Action: Update status or time
        incoming().diff(existing()).affectedKeys().hasAny(['status', 'date', 'notes']) &&
        // Prevent editing if finished or cancelled (terminal states)
        !(existing().status in ['finished', 'cancelled'])
      );
      allow delete: if isStaff();
    }

    match /transactions/{transactionId} {
      allow read: if isStaff();
      allow create: if isStaff() && isValidTransaction(incoming());
      allow update: if isStaff() && isValidTransaction(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['status', 'description', 'amount'])
      );
      allow delete: if isStaff();
    }
  }
}
