rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isMemberOf(clinicId) {
      return isSignedIn() && getUserData().clinicId == clinicId;
    }

    function hasRole(role) {
      return isSignedIn() && getUserData().role == role;
    }

    function isAdminOf(clinicId) {
      return isMemberOf(clinicId) && (getUserData().role == 'admin' || get(/databases/$(database)/documents/clinics/$(clinicId)).data.ownerId == request.auth.uid);
    }

    // --- Validation Helpers ---
    function isValidUser(data) {
      return data.keys().hasAll(['name', 'email', 'role', 'clinicId']) &&
             data.keys().size() == 4 &&
             data.name is string && data.name.size() <= 100 &&
             data.email == request.auth.token.email &&
             data.role in ['admin', 'dentist', 'receptionist', 'finance'] &&
             isValidId(data.clinicId);
    }

    function isValidPatient(data) {
      return data.keys().hasAll(['name', 'clinicId']) &&
             data.name is string && data.name.size() <= 100 &&
             isValidId(data.clinicId) &&
             (data.get('email', '') is string) &&
             (data.get('cpf', '') is string);
    }

    function isValidAppointment(data) {
      return data.keys().hasAll(['patientId', 'dentistId', 'date', 'clinicId', 'status']) &&
             isValidId(data.patientId) &&
             isValidId(data.dentistId) &&
             isValidId(data.clinicId) &&
             data.status in ['scheduled', 'confirmed', 'ongoing', 'finished', 'cancelled'];
    }

    // --- Rules ---
    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isMemberOf(getUserData().clinicId));
      allow create: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming());
      allow update: if isSignedIn() && request.auth.uid == userId && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['name']) &&
                    isValidUser(incoming());
    }

    match /clinics/{clinicId} {
      allow get: if isSignedIn() && isMemberOf(clinicId);
      allow create: if isSignedIn() && incoming().ownerId == request.auth.uid;
      allow update: if isSignedIn() && isAdminOf(clinicId) && 
                    incoming().ownerId == existing().ownerId;
    }

    match /patients/{patientId} {
      allow get: if isSignedIn() && isMemberOf(existing().clinicId);
      allow list: if isSignedIn() && resource.data.clinicId == getUserData().clinicId;
      allow create: if isSignedIn() && isMemberOf(incoming().clinicId) && isValidPatient(incoming());
      allow update: if isSignedIn() && isMemberOf(existing().clinicId) && isValidPatient(incoming());
    }

    match /appointments/{appointmentId} {
      allow get: if isSignedIn() && isMemberOf(existing().clinicId);
      allow list: if isSignedIn() && resource.data.clinicId == getUserData().clinicId;
      allow create: if isSignedIn() && isMemberOf(incoming().clinicId) && isValidAppointment(incoming());
      allow update: if isSignedIn() && isMemberOf(existing().clinicId) && isValidAppointment(incoming());
    }

    match /dentists/{dentistId} {
      allow get: if isSignedIn() && isMemberOf(existing().clinicId);
      allow list: if isSignedIn() && resource.data.clinicId == getUserData().clinicId;
      allow create: if isSignedIn() && isAdminOf(incoming().clinicId);
      allow update: if isSignedIn() && isAdminOf(existing().clinicId);
    }

    match /transactions/{transactionId} {
      allow read: if isSignedIn() && isMemberOf(resource.data.clinicId) && (hasRole('admin') || hasRole('finance'));
      allow create: if isSignedIn() && isMemberOf(incoming().clinicId) && (hasRole('admin') || hasRole('finance'));
      allow update: if isSignedIn() && isAdminOf(existing().clinicId);
    }
  }
}
